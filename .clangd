CompileFlags:
  CompilationDatabase: build
  Add:
    - --target=x86_64-pc-windows-msvc
    - -fms-compatibility
    - -fms-extensions
    - -xc++
    - -IP:/Github/VoxelEngine/engine_test/voxel_engine/src
